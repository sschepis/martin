{
  "name": "@sschepis/martin",
  "version": "1.0.3",
  "type": "module",
  "description": "An LLM-driven media director for AI video generation",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sschepis/martin.git"
  },
  "scripts": {
    "build": "node build-knowledge.js && tsc",
    "e2e": "node --import tsx examples/e2e.ts",
    "test": "node --import tsx --test \"src/**/*.test.ts\" \"src/*.test.ts\"",
    "test:manual": "tsx test.ts"
  },
  "keywords": [
    "ai",
    "video",
    "generation",
    "llm",
    "prompting",
    "runway",
    "sora",
    "luma"
  ],
  "author": "Sebastian Schepis",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "dotenv": "^17.4.2",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
